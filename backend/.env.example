# Copy to .env and adjust for your environment.

# Environment: development | production
ENVIRONMENT=development

# Security — REQUIRED in production. Generate a long random value, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=dev-secret-change-me-in-production-please-use-a-random-value

# Token lifetime in minutes (default 7 days)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database — default is a local SQLite file.
# For production use Postgres, e.g.:
#   DATABASE_URL=postgresql+psycopg://user:password@host:5432/clt_tj
DATABASE_URL=sqlite:///./clt_tj.db

# CORS — comma-separated allowed origins for the SPA.
# In single-process deploys (API serves the built SPA) this can stay as-is.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173
